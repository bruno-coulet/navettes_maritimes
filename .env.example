# Example environment variables for navettes_maritimes
# Copy this file to `.env` and fill real values (do NOT commit secrets).

# Network / Proxy (example values)
# HTTP_PROXY should point to your corporate proxy if required.
HTTP_PROXY=http://proxy.example:3128
HTTPS_PROXY=http://proxy.example:3128
ALL_PROXY=

# Service ports
NAVETTES_PRED_PORT=8000
STREAMLIT_PORT=8501

# Public API URL used by the Streamlit frontend
API_URL=https://api.example.com/predict

# Paths used by services and Docker (use absolute paths in containers)
METEO_DATA_PATH=./data/meteo
MODEL_PATH=./data/artifacts/model.pkl
FEATURES_PATH=./data/artifacts/features.json

# Helper flag kept for backward compatibility
METEO_EXAMPLE_PROXY=0
