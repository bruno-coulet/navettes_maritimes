# Example env for meteo_marine
# Copy to .env if you need local overrides for proxy detection.

# Proxy entreprise pour les requêtes sortantes
HTTP_PROXY=http://proxy.example:3128
HTTPS_PROXY=http://proxy.example:3128
ALL_PROXY=

# Option d'exemple utilisée par `main.py` et le docker-compose historique
METEO_EXAMPLE_PROXY=0