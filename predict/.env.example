# Example env for the navettes service
# Copy to .env and adjust paths/ports for local or Docker usage.

# Where the trained model is located (container path or host path)
MODEL_PATH=./data/artifacts/model.pkl

# Where the features metadata is located
FEATURES_PATH=./data/artifacts/features.json

# Port used by the service (can be overridden by docker-compose)
NAVETTES_PRED_PORT=8000
